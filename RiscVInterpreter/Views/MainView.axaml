<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:avaloniaedit="https://github.com/avaloniaui/avaloniaedit"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:RiscVInterpreter.ViewModels"
             mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="720"
             x:Class="RiscVInterpreter.Views.MainView"
             x:DataType="vm:MainViewModel">
  <Design.DataContext>
    <!-- This only sets the DataContext for the previewer in an IDE,
         to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
    <vm:MainViewModel />
  </Design.DataContext>

    <UserControl.Styles>
        <Style Selector="Border.Big">
            <Setter Property="Margin" Value="5, 5" />
            <Setter Property="BorderBrush" Value="White" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="CornerRadius" Value="2" />
            <Setter Property="Background" Value="#0d0d0d" />
        </Style>
        <Style Selector="Border.Small">
            <Setter Property="Margin" Value="5, 5" />
            <Setter Property="BorderBrush" Value="White" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="2" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>
    </UserControl.Styles>
  
    <Grid Name="MainGrid"
          RowDefinitions="auto, *"
          Background="#2b2b2b">
        
        <Grid Name="Topbar"
              ColumnDefinitions="*, *, *"
              Background="WhiteSmoke"
              Grid.Row="0">
        
            <Border Grid.Column="1" Classes="Big" Background="gray">
            <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                <Button Content="▶️" Command="{Binding PlayPressed}"/>
                <Button Content="⏸️" Command="{Binding PausePressed}"/>
                <Button Content="⏹️" Command="{Binding StopPressed}"/>
            </StackPanel>
            </Border>
        </Grid>
        
        <Grid Name="SideSplit"
              ColumnDefinitions="*, auto"
              Grid.Row="1">
            
            <Grid Name="HorisontalSplitTextConsole"
                RowDefinitions="6*, auto"
                Grid.Column="0">
                
                
                <Border Grid.Row="0" Classes="Big">
                <avaloniaedit:TextEditor Name="TextEdit"
                                         Document="{Binding EditableTextDocument, Mode=TwoWay}"
                                         HorizontalAlignment="Stretch"
                                         VerticalAlignment="Stretch"
                                         ShowLineNumbers="True"
                                         Watermark="Start typing to begin"
                                         FontFamily="Cascadia Code,Consolas,Menlo,Monospace"
                                         >
                                         
                </avaloniaedit:TextEditor>
                </Border>
                
                <Border Grid.Row="1" Classes="Big">
                <Grid Name="Console"
                    RowDefinitions="*, auto"
                    Height="150">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" AllowAutoHide="False">
                    <SelectableTextBlock Text="Heisannaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa" Grid.Row="0" TextWrapping="Wrap"/>
                    </ScrollViewer>
                    <TextBox Grid.Row="1"></TextBox>
                </Grid>
                </Border>
            </Grid>
            
            <Grid Name="HorisontalSplitMemory"
                  RowDefinitions="auto, *, auto, *"
                  Grid.Column="1"
                  >
                
            <Border Grid.Row="0" Classes="Big"><TextBlock Padding="2" Text="Registers"/></Border>
            <Border Grid.Row="1" Classes="Big">
                <ScrollViewer AllowAutoHide="False">
                <StackPanel ClipToBounds="True">
                <ItemsControl Name="RegistersItems"
                              ItemsSource="{Binding RegisterList}"
                              VerticalAlignment="Top"
                              >
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Classes="Small">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch">
                            <TextBlock Text="{Binding name}" Width="60" VerticalAlignment="Center"></TextBlock>
                            <SelectableTextBlock Text="{Binding visibleValue, Mode=TwoWay, StringFormat={}Hex:{0:X8}  Bin:{0:b32}}" FontFamily="Cascadia Code,Consolas,Menlo,Monospace" VerticalAlignment="Center"></SelectableTextBlock>
                            </StackPanel>
                        <NumericUpDown FontFamily="Cascadia Code,Consolas,Menlo,Monospace" Value="{Binding visibleValue}" MinWidth="50" Maximum="2147483647" Minimum="-2147483647" ParsingNumberStyle="Integer" ShowButtonSpinner="False"></NumericUpDown>
                        </StackPanel>
                    </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
                </ItemsControl>
                </StackPanel>
                </ScrollViewer>
            </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
