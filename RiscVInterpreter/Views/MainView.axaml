<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:RiscVInterpreter.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="RiscVInterpreter.Views.MainView"
             x:DataType="vm:MainViewModel">
  <Design.DataContext>
    <!-- This only sets the DataContext for the previewer in an IDE,
         to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
    <vm:MainViewModel />
  </Design.DataContext>

    <Grid Name="MainGrid"
          RowDefinitions="1*, 5*, 3*"
          Background="HotPink">
        
        <Grid Name="Topbar"
              RowDefinitions="3*, 1*"
              Background="Red"
              Grid.Row="0">
        
            
        </Grid>
        
        <Grid Name="TextAndMemory"
              RowDefinitions="3*, 1*"
              Background="Aqua"
              Grid.Row="1">
            
            <TextBox VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Grid.Row="0"></TextBox>
            <TextBlock Text="Hi this is a test" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Grid.Row="1"></TextBlock>
        </Grid>
        
        <Grid Name="Information"
              RowDefinitions="3*, 1*"
              Background="Red"
              Grid.Row="0">
        
        </Grid>
    </Grid>
</UserControl>
